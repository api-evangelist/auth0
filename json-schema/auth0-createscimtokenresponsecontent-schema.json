        "type": "string",
        "description": "The token's scope"
      }
    },
    "created_at": {
      "type": "string",
      "description": "The token's created at timestamp"
    },
    "valid_until": {
      "type": "string",
      "description": "The token's valid until at timestamp"
    }
  }
