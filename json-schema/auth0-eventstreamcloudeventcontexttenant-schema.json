{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/EventStreamCloudEventContextTenant",
  "title": "EventStreamCloudEventContextTenant",
  "type": "object",
  "description": "Reference to a tenant in event context",
  "additionalProperties": false,
  "required": [
    "tenant_id"
  ],
  "properties": {
    "tenant_id": {
      "type": "string",
      "description": "Machine-generated unique tenant identifier.",
      "pattern": "ten_[a-zA-Z0-9]{16}"
    }
  }
}