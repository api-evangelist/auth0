{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/FormBlockResendButtonConfig",
  "title": "FormBlockResendButtonConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "active_text",
    "button_text",
    "waiting_text",
    "flow_id"
  ],
  "properties": {
    "active_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "button_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "waiting_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "text_alignment": {
      "$ref": "#/components/schemas/FormBlockResendButtonConfigTextAlignmentEnum"
    },
    "flow_id": {
      "type": "string",
      "maxLength": 30,
      "format": "flow-id"
    },
    "max_attempts": {
      "type": "number",
      "minimum": 1,
      "maximum": 10
    },
    "waiting_time": {
      "type": "number",
      "minimum": 1,
      "maximum": 60
    }
  }
}