{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/FormWidgetAuth0VerifiableCredentialsConfig",
  "title": "FormWidgetAuth0VerifiableCredentialsConfig",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "url",
    "alternate_text",
    "access_token",
    "verification_id"
  ],
  "properties": {
    "url": {
      "type": "string",
      "maxLength": 2000
    },
    "size": {
      "type": "number",
      "minimum": 1,
      "maximum": 500
    },
    "alternate_text": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "access_token": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000
    },
    "verification_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255
    },
    "max_wait": {
      "type": "number",
      "minimum": 60,
      "maximum": 600
    }
  }
}