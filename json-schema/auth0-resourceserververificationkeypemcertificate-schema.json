{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ResourceServerVerificationKeyPemCertificate",
  "title": "ResourceServerVerificationKeyPemCertificate",
  "type": "string",
  "description": "PEM-encoded certificate",
  "allOf": [
    {
      "type": "string",
      "pattern": "^-----BEGIN[^\r\n]*-----(?:\r\n?|\n)"
    },
    {
      "type": "string",
      "pattern": "(?:\r\n?|\n)-----END[^\r\n]*-----(?:\r\n?|\n)$"
    }
  ]
}