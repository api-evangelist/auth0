{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/FlowActionSalesforceSearchLeadsParams",
  "title": "FlowActionSalesforceSearchLeadsParams",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "connection_id",
    "search_field",
    "search_value",
    "lead_fields"
  ],
  "properties": {
    "connection_id": {
      "type": "string",
      "maxLength": 30,
      "format": "flows-vault-connections-id"
    },
    "search_field": {
      "type": "string",
      "enum": [
        "email",
        "name",
        "phone",
        "all"
      ]
    },
    "search_value": {
      "type": "string",
      "maxLength": 2000
    },
    "lead_fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "maxLength": 2000
      }
    }
  }
}