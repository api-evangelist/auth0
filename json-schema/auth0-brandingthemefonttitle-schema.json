{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/BrandingThemeFontTitle",
  "title": "BrandingThemeFontTitle",
  "type": "object",
  "description": "Title",
  "additionalProperties": false,
  "required": [
    "bold",
    "size"
  ],
  "properties": {
    "bold": {
      "type": "boolean",
      "description": "Title bold"
    },
    "size": {
      "type": "number",
      "description": "Title size",
      "minimum": 75,
      "maximum": 150
    }
  }
}