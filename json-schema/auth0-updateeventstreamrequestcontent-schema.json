        "$ref": "#/components/schemas/EventStreamSubscription"
      }
    },
    "destination": {
      "$ref": "#/components/schemas/EventStreamDestinationPatch"
    },
    "status": {
      "$ref": "#/components/schemas/EventStreamStatusEnum"
    }
  }
}