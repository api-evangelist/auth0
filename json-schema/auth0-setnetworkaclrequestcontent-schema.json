{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SetNetworkAclRequestContent",
  "title": "SetNetworkAclRequestContent",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "description",
    "active",
    "rule"
  ],
  "properties": {
    "description": {
      "type": "string",
      "maxLength": 255
    },
    "active": {
      "type": "boolean",
      "description": "Indicates whether or not this access control list is actively being used"
    },
    "priority": {
      "type": "number",
      "description": "Indicates the order in which the ACL will be evaluated relative to other ACL rules.",
      "default": 50,
      "minimum": 1,
      "maximum": 100
    },
    "rule": {
      "$ref": "#/components/schemas/NetworkAclRule"
    }
  }
}