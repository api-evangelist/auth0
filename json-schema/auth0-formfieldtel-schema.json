{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/FormFieldTel",
  "title": "FormFieldTel",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "category",
    "type"
  ],
  "properties": {
    "id": {
      "type": "string",
      "format": "forms-custom-identifier"
    },
    "category": {
      "$ref": "#/components/schemas/FormComponentCategoryFieldConst"
    },
    "type": {
      "$ref": "#/components/schemas/FormFieldTypeTelConst"
    },
    "config": {
      "$ref": "#/components/schemas/FormFieldTelConfig"
    },
    "label": {
      "type": "string",
      "minLength": 1
    },
    "hint": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "required": {
      "type": "boolean"
    },
    "sensitive": {
      "type": "boolean"
    }
  }
}