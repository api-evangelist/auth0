{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/ActionModuleDependencyRequest",
  "title": "ActionModuleDependencyRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "version"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the npm dependency.",
      "maxLength": 255,
      "pattern": "^[^\u0000]*$"
    },
    "version": {
      "type": "string",
      "description": "The version of the npm dependency.",
      "maxLength": 50,
      "pattern": "^[^\u0000]*$"
    }
  }
}