    },
    "sid": {
      "type": "string"
    },
    "delivery_methods": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/components/schemas/TwilioProviderDeliveryMethodEnum"
      }
    }
  }
}