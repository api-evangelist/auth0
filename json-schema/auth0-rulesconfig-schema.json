{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/RulesConfig",
  "title": "RulesConfig",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "key": {
      "type": "string",
      "description": "Key for a rules config variable.",
      "default": "MY_RULES_CONFIG_KEY",
      "minLength": 1,
      "maxLength": 127,
      "pattern": "^[A-Za-z0-9_\\-@*+:]*$"
    }
  }
}